# .env.example — copy to .env.local and fill in values

# Groq API (free, no credit card required)
GROQ_API_KEY=

# Turso database (for progress storage)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Owner token for API protection (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
OWNER_TOKEN=
NEXT_PUBLIC_OWNER_TOKEN=

# Optional: culture notes toggle
ENABLE_CULTURE_NOTES=true